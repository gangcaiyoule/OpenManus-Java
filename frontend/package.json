{
  "name": "openmanus-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:smoke-ui": "node ./scripts/smoke-ui.mjs",
    "test:deep": "npm run test:ci && npm run build && npm run test:smoke-ui",
    "smoke": "npm run test:smoke-ui"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.2.0",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sockjs-client": "^1.6.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "playwright": "^1.58.2",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vitest": "^2.0.4"
  }
}
