<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 导入Spring Boot默认配置 -->
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <appender name="WEBSOCKET" class="com.openmanus.infra.log.WebSocketLogAppender">
    </appender>

    <logger name="com.openmanus" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="WEBSOCKET" />
    </logger>

    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.messaging" level="INFO" />
    <logger name="org.springframework.web.socket" level="INFO" />
    <logger name="org.springframework.web.socket.config.WebSocketMessageBrokerStats" level="WARN" />
    
    <!-- 默认为继承root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
